[list_begin itemized]
[item] Type: [const "path"]
[list_end]

[def "Parameter name: [emph "clientcapath"]"]
Trusted CA certificates directory for client certificate validation; relative paths are resolved against the home directory

[list_begin itemized]
[item] Type: [const "path"]
[list_end]

[def "Parameter name: [emph "clientcertmode"]"]
Client certificate request mode

[list_begin itemized]
[item] Type: [const "enum"]
[item] Allowed values: [const "none"], [const "request"], [const "require"]
