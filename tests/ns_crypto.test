test ns_crypto::kem-1.3 {syntax: ns_crypto::kem encapsulate} -constraints {kem} -body {
    ns_crypto::kem encapsulate x
} -returnCodes error -result {wrong # args: should be "ns_crypto::kem encapsulate ?-encoding hex|base64url|base64|binary? ?-passphrase /value/? -pem /value/"}

test ns_crypto::kem-1.4 {syntax: ns_crypto::kem decapsulate} -constraints {kem} -body {
    ns_crypto::kem decapsulate
} -returnCodes error -result {wrong # args: should be "ns_crypto::kem decapsulate ?-encoding hex|base64url|base64|binary? ?-passphrase /value/? -pem /value/ -ciphertext /value/"}


test ns_crypto::kem-2.1 {ns_crypto::kem end-to-end with PEM string} -constraints {kem tcl86} -body {
    set pem [ns_crypto::kem generate]

    set r [ns_crypto::kem encapsulate -pem $pem]
    set ciphertext [dict get $r ciphertext]
    set secret1 [dict get $r secret]

    set secret2 [ns_crypto::kem decapsulate -pem $pem -ciphertext [binary decode hex $ciphertext]]
    string equal $secret1 $secret2
} -returnCodes {error ok} -result 1

test ns_crypto::kem-2.2  {ns_crypto::kem end-to-end with exported public key} -constraints {kem tcl86} -body {
    set pem [ns_crypto::kem generate]
    set pub [ns_crypto::kem pub -pem $pem]

    set r [ns_crypto::kem encapsulate -pem $pub]
    set ciphertext [dict get $r ciphertext]
    set secret1 [dict get $r secret]

    set secret2 [ns_crypto::kem decapsulate -pem $pem -ciphertext [binary decode hex $ciphertext]]
    string equal $secret1 $secret2
} -returnCodes {error ok} -result 1

test ns_crypto::kem-2.3 {ns_crypto::kem end-to-end with exported public key and binary output} -constraints {kem} -body {
    set pem [ns_crypto::kem generate]
    set pub [ns_crypto::kem pub -pem $pem]

    set r [ns_crypto::kem encapsulate -pem $pub -encoding binary]
    set ciphertext [dict get $r ciphertext]
    set secret1 [dict get $r secret]

    set secret2 [ns_crypto::kem decapsulate -pem $pem -ciphertext $ciphertext -encoding binary]

    string equal $secret1 $secret2
} -returnCodes {error ok} -result 1

test ns_crypto::kem-2.5 {ns_crypto::kem roundtrip} -constraints {kem} -body {
    set pem [ns_crypto::kem generate]
    set pub [ns_crypto::kem pub -pem $pem]

    set r [ns_crypto::kem encapsulate -pem $pub]
    set ciphertext [dict get $r ciphertext]
    set secret1 [dict get $r secret]

    set secret2 [ns_crypto::kem decapsulate -pem $pem -ciphertext [binary decode hex $ciphertext]]

    # note, that we getting the length of the hex-encoded values
    list \
        [string length $ciphertext] \
        [string length $secret1] \
        [string equal $secret1 $secret2]
} -returnCodes {error ok} -result {2176 64 1}


