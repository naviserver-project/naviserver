    ns_crypto::key pub
} -returnCodes error -result {wrong # args: should be "ns_crypto::key pub ?-encoding hex|base64url|base64|binary? ?-format raw|pem? ?-passphrase /value/? ?-outfile /value/? -pem /value/"}

