test ns_crypto::signature-7.1 {Ed25519 sign/verify roundtrip} -constraints {signature ed25519} -body {
    set priv [ns_crypto::signature generate -name ed25519]
    set pub [ns_crypto::signature pub -pem $priv]
    set sig [ns_crypto::signature sign -encoding binary -pem $priv "hello"]
    ns_crypto::signature verify -pem $pub -signature $sig "hello"
} -cleanup {
