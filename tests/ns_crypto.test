############################################################################
# Test Cases for JWT/JWK
############################################################################

namespace eval jwt {}
proc ::jwt::public_key_from_jwk {jwk} {
    set kty [dict get $jwk kty]

    switch -- $kty {
        EC {
            set crv [dict get $jwk crv]
            set curveMap {
                P-256 prime256v1
                P-384 secp384r1
                P-521 secp521r1
                secp256k1 secp256k1
            }
            if {![dict exists $curveMap $crv]} {
                error "unsupported EC curve \"$crv\""
            }
            set group [dict get $curveMap $crv]
            set x [ns_base64urldecode -binary [dict get $jwk x]]
            set y [ns_base64urldecode -binary [dict get $jwk y]]

            return [ns_crypto::key import \
                        -name EC \
                        -params [dict create group $group x $x y $y]]
        }
        RSA {
            set n [ns_base64urldecode -binary [dict get $jwk n]]
            set e [ns_base64urldecode -binary [dict get $jwk e]]
            return [ns_crypto::key import \
                        -name RSA \
                        -params [dict create n $n e $e]]
        }
        OKP {
            set crv [dict get $jwk crv]
            set x [ns_base64urldecode -binary [dict get $jwk x]]
            return [ns_crypto::key import \
                        -name OKP \
                        -params [dict create crv $crv x $x]]
        }
        default {
            error "unsupported JWK kty \"$kty\""
        }
    }
}

proc ::jwt::alg_to_verify_spec {alg} {
    switch -- $alg {
        ES256  { return {keytype EC  digest sha256} }
        ES256K { return {keytype EC  digest sha256} }
        ES384  { return {keytype EC  digest sha384} }
        ES512  { return {keytype EC  digest sha512} }

        RS256  { return {keytype RSA digest sha256} }
        RS384  { return {keytype RSA digest sha384} }
        RS512  { return {keytype RSA digest sha512} }

        default {
            error "unsupported JWT alg \"$alg\""
        }
    }
}

#---------------------------------------------------------------------------
# JWT/JWK adapter-style regression tests based on helper procs
#---------------------------------------------------------------------------

test ns_crypto::jwk-1.0 {JWK helpers: verify all supported ES* algorithms} \
    -constraints {keygen ec tcl86 secp256k1} \
    -body {
        set curveMap {
            ES256  {nsCurve prime256v1 jwkCrv P-256     coordLen 32}
            ES256K {nsCurve secp256k1  jwkCrv secp256k1 coordLen 32}
            ES384  {nsCurve secp384r1  jwkCrv P-384     coordLen 48}
            ES512  {nsCurve secp521r1  jwkCrv P-521     coordLen 66}
        }
        set results {}
        foreach {alg details} $curveMap {
            dict with details {
                #
                # Generate EC key pair on the required curve
                #
                set privpem   [ns_crypto::key generate -name EC -group $nsCurve]
                set pubrawHex [ns_crypto::key pub -pem $privpem -encoding hex]
                set pubraw    [binary decode hex $pubrawHex]

                if {[string length $pubraw] != (1 + 2 * $coordLen)
                    || [string index $pubraw 0] ne "\x04"} {
                    error "bad EC public point for $alg"
                }

                set x [string range $pubraw 1 $coordLen]
                set y [string range $pubraw [expr {$coordLen + 1}] end]

                #
                # Build JWK-like dict and import public key
                #
                set jwk [dict create \
                             kty EC \
                             crv $jwkCrv \
                             x [ns_base64urlencode -binary -- $x] \
                             y [ns_base64urlencode -binary -- $y]]

                set pubpem2 [::jwt::public_key_from_jwk $jwk]
                set spec    [::jwt::alg_to_verify_spec $alg]
                set digest  [dict get $spec digest]

                #
                # Sign/verify roundtrip
                #
                set data "hello $alg\n"
                set sig [ns_crypto::md string -digest $digest -encoding binary -sign $privpem $data]
                lappend results $alg [ns_crypto::md string -digest $digest -encoding binary \
                                          -verify $pubpem2 -signature $sig $data]
            }
        }
        set results
    } \
    -returnCodes {error ok} \
    -result {ES256 1 ES256K 1 ES384 1 ES512 1}


test ns_crypto::jwk-2.0 {JWK helpers: verify all supported RS* algorithms} \
    -constraints {keygen signature tcl86} \
    -body {
        set results {}
        foreach alg {RS256 RS384 RS512} {
            #
            # Generate RSA key pair
            #
            set privpem [ns_crypto::signature generate -name RSA]
            set info [ns_crypto::key info -pem $privpem -encoding binary]

            set n [dict get $info n]
            set e [dict get $info e]

            #
            # Build JWK-like dict and import public key
            #
            set jwk [dict create \
                         kty RSA \
                         n [ns_base64urlencode -binary -- $n] \
                         e [ns_base64urlencode -binary -- $e]]

            set pubpem2 [::jwt::public_key_from_jwk $jwk]
            set spec    [::jwt::alg_to_verify_spec $alg]
            set digest  [dict get $spec digest]

            #
            # Sign/verify roundtrip
            #
            set data "hello $alg\n"
            set sig [ns_crypto::md string -digest $digest -encoding binary -sign $privpem $data]
            lappend results $alg [ns_crypto::md string -digest $digest -encoding binary \
                                      -verify $pubpem2 -signature $sig $data]
        }
        set results
    } \
    -returnCodes {error ok} \
    -result {RS256 1 RS384 1 RS512 1}

test ns_crypto::jwk-3.0 {JWK helpers: verify all supported OKP algorithms} \
    -constraints {keygen tcl86 ed25519 x25519 ed448} \
    -body {

        #
        # Map alg → parameters (similar to EC map)
        #
        set okp_map {
            EdDSA  {name Ed25519 type signature}
            Ed448  {name Ed448   type signature}
            X25519 {name X25519 type agreement}
        }

        set results {}

        foreach {alg details} $okp_map {
            dict with details {

                #
                # Generate key
                #
                set privpem [ns_crypto::key generate -name $name]
                set pubraw  [ns_crypto::key pub -pem $privpem -encoding binary]

                #
                # Import via OKP
                #
                set pubpem2 [ns_crypto::key import \
                                 -name OKP \
                                 -params [dict create crv $name x $pubraw]]

                #
                # Verify behavior
                #
                if {$type eq "signature"} {
                    set data "hello\n"
                    set sig [ns_crypto::signature sign -binary -pem $privpem -- $data]

                    set ok [ns_crypto::signature verify \
                                -binary \
                                -pem $pubpem2 \
                                -signature [binary decode hex $sig] \
                                -- $data]
                    lappend results $alg $ok

                } else {
                    #
                    # For X25519: just check capability
                    #
                    set info [ns_crypto::key info -pem $pubpem2]
                    lappend results $alg [dict get $info agreement]
                }
            }
        }

        set results

    } \
    -returnCodes {error ok} \
    -result {EdDSA 1 Ed448 1 X25519 1}


