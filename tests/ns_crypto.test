test ns_jwt-1.0.1 {syntax: decode without argument} -body {
    ns_jwt decode
} -returnCodes error -result {wrong # args: should be "decode token"}
# message should be {wrong # args: should be "ns_jwt decode /token/"}

test ns_jwt-1.0.2 {syntax: encode without argument} -body {
    ns_jwt encode
} -match glob -returnCodes error -result {required argument 'alg' is missing, should be:*:ns_jwt encode -alg /value/ ?-key /value/? ?-jwk /value/? ?-secret /value/? ?-kid /value/? ?-typ /value/? ?-cty /value/? ?-extraheader /value/? ?-iss /value/? ?-sub /value/? ?-aud /value/? ?-exp /value/? ?-nbf /value/? ?-iat /value/? ?-jti /value/? ?/extrapayload/?}
# message should be {wrong # args: should be "ns_jwt encode -alg /value/ ?-key /value/? ?-jwk /value/? ?-secret /value/? ?-kid /value/? ?-typ /value/? ?-cty /value/? ?-extraheader /value/? ?-iss /value/? ?-sub /value/? ?-aud /value/? ?-exp /value/? ?-nbf /value/? ?-iat /value/? ?-jti /value/? ?/extrapayload/?"}

