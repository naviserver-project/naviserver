    set pem [ns_crypto::signature generate -name ml-dsa-65]
    set type [ns_crypto::key type -pem $pem]
    string match "ml-dsa-*" $type
} -result 1

test ns_crypto::signature-8.4 {ML-DSA pub returns PEM public key} -constraints {mldsa} -body {
    set pem [ns_crypto::signature generate -name ml-dsa-65]
    set pubpem [ns_crypto::signature pub -pem $pem]
    expr {[string match {*-----BEGIN PUBLIC KEY-----*} $pubpem]}
} -result 1

test ns_crypto::signature-8.5 {ML-DSA sign/verify roundtrip} -constraints {mldsa} -body {
    set pem [ns_crypto::signature generate -name ml-dsa-65]
    set pubpem [ns_crypto::signature pub -pem $pem]

    set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]
    ns_crypto::signature verify -pem $pubpem -signature $sig "hello"
} -returnCodes {error ok} -result 1

test ns_crypto::signature-8.6 {ML-DSA sign/verify roundtrip all parameter sets} -constraints {mldsa} -body {
    set r {}
    foreach name {ml-dsa-44 ml-dsa-65 ml-dsa-87} {
        set pem [ns_crypto::signature generate -name $name]
        set pubpem [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]
        lappend r [ns_crypto::signature verify -pem $pubpem -signature $sig "hello"]
    }
    set r
} -result {1 1 1}

test ns_crypto::signature-8.7 {ML-DSA verify fails on modified message} -constraints {mldsa} -body {
    set pem [ns_crypto::signature generate -name ml-dsa-65]
    set pubpem [ns_crypto::signature pub -pem $pem]
    set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]

    ns_crypto::signature verify -pem $pubpem -signature $sig "hello!"
} -returnCodes {error ok} -result 0

