        [dict get [dict get $verified payload] sub]
} -result {1 HS384 alice}

test ns_jwt-hmac-3.2 {verify: valid HS512 token with shared secret} -body {
    set token [ns_jwt encode \
                   -alg HS512 \
                   -secret "s3cr3t" \
                   -sub alice]

    set verified [ns_jwt verify -secret "s3cr3t" $token]

    list \
