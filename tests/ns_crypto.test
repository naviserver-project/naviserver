test ns_hmac_sha1-1.1 {ns_hmac with sha1 digest} -body {
     ns_crypto::hmac string -digest sha1 "Jefe" "what do ya want for nothing?"
} -result "effcdf6ae5eb2fa2d27416d5f184df9c259a7c79"

