test ns_crypto::signature-8.11 {ML-DSA pub can write outfile} -constraints {mldsa} -setup {
    set privFile /tmp/ns_crypto_mldsa_priv.pem
    set pubFile  /tmp/ns_crypto_mldsa_pub.pem
    file delete -force $privFile $pubFile
} -body {
    set pem [ns_crypto::signature generate -name ml-dsa-65 -outfile $privFile]
    ns_crypto::signature pub -pem $privFile -outfile $pubFile
    expr {[file exists $pubFile] && [file size $pubFile] > 0}
} -cleanup {
    file delete -force $privFile $pubFile
} -result 1

