test ns_crypto::key-3.1 {info: EC private key has type, curve, bits} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set info [ns_crypto::key info -pem $pem]
    list \
        [dict get $info type] \
        [dict get $info curve] \
        [dict get $info bits]
} -result {ec prime256v1 256}

test ns_crypto::key-3.2 {info: EC public key has type, curve, bits} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]
    set info [ns_crypto::key info -pem $pubpem]
    list \
        [dict get $info type] \
        [dict get $info curve] \
        [dict get $info bits]
} -result {ec prime256v1 256}

test ns_crypto::key-3.3 {info: EC curve exists} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set info [ns_crypto::key info -pem $pem]
    expr {[dict get $info type] eq "ec" && [dict exists $info curve] && [dict exists $info bits]}
} -result 1

