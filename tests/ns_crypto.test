#---------------------------------------------------------------------------
# ns_crypto::key import
#---------------------------------------------------------------------------

test ns_crypto::key-8.1 {ns_crypto::key import EC public key from coords} -constraints {keygen ec tcl86} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set Phex [ns_crypto::eckey pub -pem $pem -encoding hex]
    set Pbin [binary decode hex $Phex]

    if {[string length $Pbin] != 65 || [string index $Pbin 0] ne "\x04"} {
        error "bad point"
    }

    set x [string range $Pbin 1 32]
    set y [string range $Pbin 33 64]

    set pubpem2 [ns_crypto::key import -name EC -params [dict create group prime256v1 x $x y $y]]

    if {![string match "-----BEGIN PUBLIC KEY-----*" $pubpem2]} {
        error "bad pem: $pubpem2"
    }

    set data "hello\n"
    set sig [ns_crypto::md string -digest sha256 -encoding binary -sign $pem $data]
    ns_crypto::md string -digest sha256 -encoding binary -verify $pubpem2 -signature $sig $data
} -returnCodes {error ok} -result {1}

test ns_crypto::key-8.2 {ns_crypto::key import EC public key from coords raw} -constraints {keygen ec tcl86} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set Phex [ns_crypto::eckey pub -pem $pem -encoding hex]
    set Pbin [binary decode hex $Phex]

    set x [string range $Pbin 1 32]
    set y [string range $Pbin 33 64]

    set pubraw [ns_crypto::key import -name EC -format raw -encoding binary \
                    -params [dict create group prime256v1 x $x y $y]]

    string equal $pubraw $Pbin
} -result 1

test ns_crypto::key-8.3 {ns_crypto::key import EC requires x and y} -constraints {keygen ec} -body {
    ns_crypto::key import -name EC -params [dict create group prime256v1 x abc]
} -returnCodes error -match glob -result {*requires dict keys "group", "x", and "y"*}


test ns_crypto::key-8.4 {ns_crypto::key import RSA public key from modulus/exponent} \
    -constraints {keygen signature tcl86} \
    -body {
        #
        # Generate RSA key pair
        #
        set privpem [ns_crypto::key generate -name RSA]

        #
        # Extract modulus and exponent as hex data
        #
        set info [ns_crypto::key info -pem $privpem -encoding binary]
        set n [dict get $info n]
        set e [dict get $info e]

        #
        # Import public key from n/e
        #
        set pubpem2 [ns_crypto::key import -name RSA \
                         -params [dict create n $n e $e]]

        if {![string match "-----BEGIN PUBLIC KEY-----*" $pubpem2]} {
            error "bad pem: $pubpem2"
        }

        #
        # Sign/verify roundtrip
        #
        set data "hello\n"
        set sig [ns_crypto::md string -digest sha256 -encoding binary -sign $privpem $data]

        ns_crypto::md string -digest sha256 -encoding binary -verify $pubpem2 -signature $sig $data
    } \
    -returnCodes {error ok} \
    -result {1}


test ns_crypto::key-8.5 {ns_crypto::key import OKP Ed25519 public key from x} \
    -constraints {keygen ed25519 tcl86} \
    -body {
        set privpem [ns_crypto::key generate -name Ed25519]
        set pubraw  [ns_crypto::key pub -pem $privpem -encoding binary]

        if {[string length $pubraw] != 32} {
            error "bad Ed25519 public key length"
        }

        set pubpem2 [ns_crypto::key import \
                         -name OKP \
                         -params [dict create crv Ed25519 x $pubraw]]

        if {![string match "-----BEGIN PUBLIC KEY-----*" $pubpem2]} {
            error "bad pem: $pubpem2"
        }

        set data "hello\n"
        set sig [ns_crypto::signature sign -binary -pem $privpem -- $data]
        ns_crypto::signature verify \
            -binary \
            -pem $pubpem2 \
            -signature [binary decode hex $sig] \
            -- $data
    } \
    -returnCodes {error ok} \
    -result {1}


test ns_crypto::key-8.6 {ns_crypto::key import OKP Ed25519 public key raw} \
    -constraints {keygen ed25519 tcl86} \
    -body {
        set privpem [ns_crypto::key generate -name Ed25519]
        set pubraw  [ns_crypto::key pub -pem $privpem -encoding binary]

        set imported [ns_crypto::key import \
                          -name OKP \
                          -format raw \
                          -encoding binary \
                          -params [dict create crv Ed25519 x $pubraw]]

        string equal $pubraw $imported
    } \
    -result 1


test ns_crypto::key-8.7 {ns_crypto::key import OKP X25519 public key from x} \
    -constraints {keygen x25519 tcl86} \
    -body {
        set privpem [ns_crypto::key generate -name X25519]
        set pubraw  [ns_crypto::key pub -pem $privpem -encoding binary]

        if {[string length $pubraw] != 32} {
            error "bad X25519 public key length"
        }

        set pubpem2 [ns_crypto::key import \
                         -name OKP \
                         -params [dict create crv X25519 x $pubraw]]

        if {![string match "-----BEGIN PUBLIC KEY-----*" $pubpem2]} {
            error "bad pem: $pubpem2"
        }

        set info [ns_crypto::key info -pem $pubpem2]
        list [dict get $info type] [dict get $info agreement]
    } \
    -result {x25519 1}


test ns_crypto::key-8.8 {ns_crypto::key import OKP requires crv and x} \
    -constraints {keygen ed25519} \
    -body {
        ns_crypto::key import -name OKP -params [dict create crv Ed25519]
    } \
    -returnCodes error \
    -match glob \
    -result {*requires dict keys "crv" and "x"*}


test ns_crypto::key-8.9 {ns_crypto::key import OKP rejects unsupported crv} \
    -constraints {keygen} \
    -body {
        ns_crypto::key import \
            -name OKP \
            -params [dict create crv Ed25518 x [binary format a32 ""]]
    } \
    -returnCodes error \
    -match glob \
    -result {*unsupported OKP curve*}


test ns_crypto::key-8.10 {ns_crypto::key import OKP validates Ed25519 public key length} \
    -constraints {keygen ed25519} \
    -body {
        ns_crypto::key import \
            -name OKP \
            -params [dict create crv Ed25519 x "abc"]
    } \
    -returnCodes error \
    -match glob \
    -result {invalid public key length for Ed25519 (need * bytes)}


test ns_crypto::key-8.11 {ns_crypto::key import OKP validates X25519 public key length} \
    -constraints {keygen x25519} \
    -body {
        ns_crypto::key import \
            -name OKP \
            -params [dict create crv X25519 x "abc"]
    } \
    -returnCodes error \
    -match glob \
    -result {invalid public key length for X25519 (need * bytes)}


test ns_crypto::key-8.12 {ns_crypto::key import OKP currently supports only public import} \
    -constraints {keygen ed25519} \
    -body {
        ns_crypto::key import \
            -name OKP \
            -from keypair \
            -params [dict create crv Ed25519 x [binary format a32 ""]]
