} -returnCodes error -result {wrong # args: should be "ns_crypto::signature pub ?-passphrase /value/? ?-outfile /value/? -pem /value/"}

test ns_crypto::signature-8.2 {ML-DSA generate default returns PEM private key} -constraints {mldsa} -body {
    set pem [ns_crypto::signature generate]
    expr {[string match {*-----BEGIN PRIVATE KEY-----*} $pem]
          || [string match {*-----BEGIN ML-DSA PRIVATE KEY-----*} $pem]}
} -result 1

