#---------------------------------------------------------------------------
# Functional tests: agreement key generation and public key extraction
#---------------------------------------------------------------------------

test ns_crypto::agreement-2.1 {generate: X25519 private key} -constraints {agreement x25519} -body {
    set pem [ns_crypto::agreement generate -name X25519]
    list \
        [string match {*-----BEGIN PRIVATE KEY-----*} $pem] \
        [dict get [ns_crypto::key info -pem $pem] type] \
        [dict get [ns_crypto::key info -pem $pem] agreement]
} -result {1 x25519 1}

test ns_crypto::agreement-2.2 {generate: X448 private key} -constraints {agreement} -body {
    set pem [ns_crypto::agreement generate -name X448]
    list \
        [string match {*-----BEGIN PRIVATE KEY-----*} $pem] \
        [dict get [ns_crypto::key info -pem $pem] type] \
        [dict get [ns_crypto::key info -pem $pem] agreement]
} -result {1 x448 1}

test ns_crypto::agreement-2.3 {pub: X25519 public key extraction} -constraints {agreement x25519} -body {
    set pem [ns_crypto::agreement generate -name X25519]
    set pub [ns_crypto::agreement pub -pem $pem]
    list \
        [string match {*-----BEGIN PUBLIC KEY-----*} $pub] \
        [dict get [ns_crypto::key info -pem $pub] type] \
        [dict get [ns_crypto::key info -pem $pub] agreement]
} -result {1 x25519 1}

test ns_crypto::agreement-2.4 {pub: X448 public key extraction} -constraints {agreement} -body {
    set pem [ns_crypto::agreement generate -name X448]
    set pub [ns_crypto::agreement pub -pem $pem]
    list \
        [string match {*-----BEGIN PUBLIC KEY-----*} $pub] \
        [dict get [ns_crypto::key info -pem $pub] type] \
        [dict get [ns_crypto::key info -pem $pub] agreement]
} -result {1 x448 1}

test ns_crypto::agreement-2.5 {generate: write X25519 key to outfile} -constraints {agreement x25519} -setup {
    set privFile /tmp/ns_crypto_x25519_priv.pem
    file delete -force $privFile
} -body {
    ns_crypto::agreement generate -name X25519 -outfile $privFile
    expr {[file exists $privFile] && [file size $privFile] > 0}
} -cleanup {
    file delete -force $privFile
    unset -nocomplain privFile
} -result 1

test ns_crypto::agreement-2.6 {pub: write X25519 public key to outfile} -constraints {agreement x25519} -setup {
    set privFile /tmp/ns_crypto_x25519_priv.pem
    set pubFile  /tmp/ns_crypto_x25519_pub.pem
    file delete -force $privFile $pubFile
    ns_crypto::agreement generate -name X25519 -outfile $privFile
} -body {
    ns_crypto::agreement pub -pem $privFile -outfile $pubFile
    expr {[file exists $pubFile] && [file size $pubFile] > 0}
} -cleanup {
    file delete -force $privFile $pubFile
    unset -nocomplain privFile pubFile
} -result 1

