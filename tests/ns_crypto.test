    set pubpem2 [ns_crypto::signature pub -pem $pem2]
    set sig [ns_crypto::signature sign -encoding binary -pem $pem1 "hello"]

    ns_crypto::signature verify -pem $pubpem2 -signature $sig "hello"
} -returnCodes {error ok} -result 0

