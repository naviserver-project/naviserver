# message should be {wrong # args: should be "ns_jwt verify ?-alg /value/? ?-key /value/? ?-jwk /value/? ?-jwks /value/? ?-secret /value/? ?-kid /value/? ?-requirekid? ?-verifyclaims? ?-aud /value/? ?-iss /value/? ?-sub /value/? ?-clockskew /value/? ?-now /value/? /token/"}

