#---------------------------------------------------------------------------
# Test Cases for ns_crypto::signature functional tests
#---------------------------------------------------------------------------

test ns_crypto::signature-2.1 {EC sign/verify roundtrip with default digest and hex encoding using default curve}\
    -constraints {ec tcl86} -body {
    set pem [ns_crypto::eckey generate]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]
    set msg "hello world"

    set sig [ns_crypto::signature sign -pem $pem $msg]
    ns_crypto::signature verify -pem $pubpem -signature [binary decode hex $sig] $msg
} -returnCodes {error ok} -result 1

test ns_crypto::signature-2.2 {EC sign/verify roundtrip with binary message and binary signature} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]
    set msg [binary format H* 00010203040506070809]

    set sig [ns_crypto::signature sign -binary -encoding binary -pem $pem $msg]
    ns_crypto::signature verify -binary -pem $pubpem -signature $sig $msg
} -returnCodes {error ok} -result 1

test ns_crypto::signature-2.3 {EC sign/verify roundtrip with explicit digest sha384 and base64url encoding} \
    -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]
    set msg "abcdefghijklmnopqrstuvwxyz"

    set sig [ns_crypto::signature sign -digest sha384 -encoding base64url -pem $pem $msg]
    ns_crypto::signature verify -digest sha384 -pem $pubpem \
        -signature [ns_base64urldecode -binary $sig] $msg
} -returnCodes {error ok} -result 1

test ns_crypto::signature-2.4 {EC verify fails on modified message} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]

    set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]

    ns_crypto::signature verify -pem $pubpem -signature $sig "hello!"
} -returnCodes {error ok} -result 0

test ns_crypto::signature-2.5a {EC verify raises on truncated signature encoding} -constraints {ec tcl86} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set pubpem [ns_crypto::eckey pub -pem $pem -format pem]
    set sig [ns_crypto::signature sign -pem $pem "hello"]
    set sigbin [binary decode hex $sig]

    ns_crypto::signature verify -pem $pubpem \
        -signature [string range $sigbin 0 end-1] \
        "hello"
} -returnCodes error -match glob -result *

test ns_crypto::signature-2.5b {EC verify returns 0 with wrong public key} -constraints {ec tcl86} -body {
    set pem1 [ns_crypto::eckey generate -name prime256v1]
    set pem2 [ns_crypto::eckey generate -name prime256v1]
    set pubpem2 [ns_crypto::eckey pub -pem $pem2 -format pem]

    set sig [ns_crypto::signature sign -pem $pem1 "hello"]
    ns_crypto::signature verify -pem $pubpem2 -signature [binary decode hex $sig] "hello"
} -result 0

test ns_crypto::signature-2.6 {EC sign/verify using private key PEM for verify} -constraints {ec} -body {
    set pem [ns_crypto::eckey generate -name prime256v1]
    set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]
    ns_crypto::signature verify -pem $pem -signature $sig "hello"
} -returnCodes {error ok} -result 1

test ns_crypto::signature-2.7 {ML-DSA sign/verify roundtrip} -constraints {mldsa} -body {
    set pem [ns_crypto::signature generate -name ml-dsa-65]
    set pubpem [ns_crypto::signature pub -pem $pem]

    set sig [ns_crypto::signature sign -encoding binary -pem $pem "hello"]
    ns_crypto::signature verify -pem $pubpem -signature $sig "hello"
} -returnCodes {error ok} -result 1


