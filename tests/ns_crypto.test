    ns_crypto::eckey fromcoords
} -returnCodes error -result {wrong # args: should be "ns_crypto::eckey fromcoords ?-binary? -curve /value/ -x /value/ -y /value/ ?-format pem|der? ?-outfile /value/?"}

test ns_crypto:eckey-1.7.0 {ns_crypto::eckey generate and return PEM as result} -constraints {ec} -body {
    ns_crypto::eckey generate -name prime256v1
} -match glob -result {*-----BEGIN EC PRIVATE KEY-----*-----END EC PRIVATE KEY-----*}

test ns_crypto:eckey-1.7.1 {ns_crypto::eckey fromcoords cycle} -constraints {ec tcl86} -body {
    ns_crypto::eckey generate -name prime256v1 -pem /tmp/p256-priv.pem
    set Phex [ns_crypto::eckey pub -pem /tmp/p256-priv.pem -encoding hex]
    set Pbin [binary decode hex $Phex]
    if {[string length $Pbin] != 65 || [string index $Pbin 0] ne "\x04"} { error "bad point" }
    set x [string range $Pbin 1 32]
    set y [string range $Pbin 33 64]
    set pubpem2 [ns_crypto::eckey fromcoords -curve prime256v1 -x $x -y $y -binary -format pem]
    if {![string match "-----BEGIN PUBLIC KEY-----*" $pubpem2]} {error "bad pem: $pubpem2"}
    set data "hello\n"
    set sig [ns_crypto::md string -digest sha256 -encoding binary -sign /tmp/p256-priv.pem $data]
    set ok [ns_crypto::md string -digest sha256 -encoding binary -verify $pubpem2 -signature $sig $data]
} -returnCodes {error ok} -result {1}


