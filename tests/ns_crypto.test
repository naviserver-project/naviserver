    ns_crypto::key
} -returnCodes error -match glob -result \
    [expr {
           [dict get [ns_info ssl -details] major] >= 3
           ? {wrong # args: should be "ns_crypto::key generate|import|info|type|pub|priv ?/arg .../"}
           : {wrong # args: should be "ns_crypto::key info|type|pub|priv ?/arg .../"}
       }]

