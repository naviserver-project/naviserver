test ns_jwt-1.0.10 {verify: alg none is rejected} -body {
    set token [ns_jwt encode \
                   -alg none \
                   -sub alice]

    ns_jwt verify -secret "s3cr3t" $token
} -returnCodes error -match glob -result {*alg=none*}


# -------------------------------------------------------------------------
# ns_jwt basic tests
# -------------------------------------------------------------------------

test ns_jwt-1.1 {encode: EdDSA creates compact JWT with 3 parts} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -kid ed1 \
                   -sub alice \
                   -iss naviserver]

    list [llength [split $token .]] [expr {[string length $token] > 20}]
} -result {3 1}

test ns_jwt-1.2 {decode: returns header and payload for EdDSA token} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -kid ed1 \
                   -sub alice \
                   -iss naviserver ]

    set decoded [ns_jwt decode $token]
    set header  [dict get $decoded header]
    set payload [dict get $decoded payload]

    list \
        [dict get $header alg] \
        [dict get $header kid] \
        [dict get $payload sub] \
        [dict get $payload iss]
} -result {EdDSA ed1 alice naviserver}

test ns_jwt-1.3 {verify: valid EdDSA token with PEM key} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]
    set pubpem  [ns_crypto::key pub -pem $privpem -format pem]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice \
                   {role string admin}]

    set verified [ns_jwt verify -key $pubpem $token]
    set payload  [dict get $verified payload]

    list \
        [dict get $verified valid] \
        [dict get $verified alg] \
        [dict get $payload sub] \
        [dict get $payload role]
} -result {1 EdDSA alice admin}

test ns_jwt-1.4 {verify: tampered payload fails} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]
    set pubpem  [ns_crypto::key pub -pem $privpem -format pem]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice]

    lassign [split $token .] h p s
    set payload [ns_json parse -output triples [ns_base64urldecode $p]]
    lappend payload sub string mallory
    set tampered_payload [ns_base64urlencode -- [ns_json value -type object $payload]]
    set tampered_token "${h}.${tampered_payload}.${s}"

    ns_jwt verify -key $pubpem $tampered_token
} -returnCodes error -match glob -result {*verification failed*}

test ns_jwt-1.5 {decode: typ defaults to JWT} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice]

    set decoded [ns_jwt decode $token]
    dict get [dict get $decoded header] typ
} -result {JWT}

test ns_jwt-1.6 {encode/decode: extra protected header triples} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -extraheader {
                       b64 boolean 0
                       crit array {1 string b64}
                   } \
                   -sub alice]

    set decoded [ns_jwt decode $token]
    set header  [dict get $decoded header]

    list \
        [dict get $header b64] \
        [lindex [dict get $header crit] 0]
} -result {false b64}


# -------------------------------------------------------------------------
# ns_jwt verify tests
# -------------------------------------------------------------------------

test ns_jwt-2.1 {verify: ES256 token with public JWK} -constraints {keygen} -body {
    set privpem [ns_crypto::key generate -name EC -group prime256v1]
    set info    [ns_crypto::key info -pem $privpem -encoding base64url]

    set jwk [dict create \
                 kty EC \
                 crv P-256 \
                 x [dict get $info x] \
                 y [dict get $info y]]

    set token [ns_jwt encode \
                   -alg ES256 \
                   -key $privpem \
                   -sub alice \
                   {scope string read}]

    set verified [ns_jwt verify -jwk $jwk $token]
    set payload  [dict get $verified payload]

    list \
        [dict get $verified valid] \
        [dict get $verified alg] \
        [dict get $payload sub] \
        [dict get $payload scope]
} -returnCodes {error ok} -result {1 ES256 alice read}

test ns_jwt-2.2 {verify: RS256 token with public JWK} -constraints {keygen} -body {
    set privpem [ns_crypto::key generate -name RSA]
    set info    [ns_crypto::key info -pem $privpem -encoding base64url]

    set jwk [dict create \
                 kty RSA \
                 n [dict get $info n] \
                 e [dict get $info e]]

    set token [ns_jwt encode \
                   -alg RS256 \
                   -key $privpem \
                   -sub alice \
                   {dept string eng}]

    set verified [ns_jwt verify -jwk $jwk $token]
    set payload  [dict get $verified payload]

    list \
        [dict get $verified valid] \
        [dict get $verified alg] \
        [dict get $payload sub] \
        [dict get $payload dept]
} -returnCodes {error ok} -result {1 RS256 alice eng}

test ns_jwt-2.3 {verify: EdDSA token with OKP public JWK} -constraints {ed25519} -body {
    set privpem [ns_crypto::key generate -name Ed25519]
    set info    [ns_crypto::key info -pem $privpem -encoding base64url]

    set jwk [dict create \
                 kty OKP \
                 crv Ed25519 \
                 x [dict get $info x]]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice]

    set verified [ns_jwt verify -jwk $jwk $token]
    list \
        [dict get $verified valid] \
        [dict get $verified alg] \
        [dict get [dict get $verified payload] sub]
} -result {1 EdDSA alice}



# -------------------------------------------------------------------------
# ns_jwt verify claims
# -------------------------------------------------------------------------

test ns_jwt-3.1 {verify: exp claim accepted when still valid} -constraints {ed25519} -body {
    set now     [clock seconds]
    set privpem [ns_crypto::key generate -name Ed25519]
    set pubpem  [ns_crypto::key pub -pem $privpem -format pem]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice \
                   -exp [expr {$now + 60}]]

    set verified [ns_jwt verify \
                      -key $pubpem \
                      -verifyclaims \
                      -now $now \
                      $token]

    list [dict get $verified valid] [dict get [dict get $verified payload] sub]
} -returnCodes {error ok} -result {1 alice}

test ns_jwt-3.2 {verify: exp claim rejected when expired} -constraints {ed25519} -body {
    set now     [clock seconds]
    set privpem [ns_crypto::key generate -name Ed25519]
    set pubpem  [ns_crypto::key pub -pem $privpem -format pem]

    set token [ns_jwt encode \
                   -alg EdDSA \
                   -key $privpem \
                   -sub alice \
                   -exp [expr {$now - 10}]]

    ns_jwt verify \
        -key $pubpem \
        -verifyclaims \
        -now $now \
        $token
} -returnCodes error -match glob -result {*expired*}

# -------------------------------------------------------------------------
# basic ns_jwt hmac tests
# -------------------------------------------------------------------------
test ns_jwt-hmac-1.1 {encode: HS256 creates compact JWT with 3 parts} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice \
                   -iss naviserver]

    list [llength [split $token .]] [expr {[string length $token] > 20}]
} -result {3 1}

test ns_jwt-hmac-1.2 {decode: returns header and payload for HS256 token} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -kid hs1 \
                   -sub alice \
                   -iss naviserver]

    set decoded [ns_jwt decode $token]
    set header  [dict get $decoded header]
    set payload [dict get $decoded payload]

    list \
        [dict get $header alg] \
        [dict get $header kid] \
        [dict get $payload sub] \
        [dict get $payload iss]
} -result {HS256 hs1 alice naviserver}

test ns_jwt-hmac-1.3 {verify: valid HS256 token with shared secret} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice \
                   {role string admin}]

    set verified [ns_jwt verify -secret "s3cr3t" $token]
    set payload  [dict get $verified payload]

    list \
        [dict get $verified valid] \
        [dict get $verified alg] \
        [dict get $payload sub] \
        [dict get $payload role]
} -result {1 HS256 alice admin}

test ns_jwt-hmac-1.4 {verify: wrong secret fails} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice]

    ns_jwt verify -secret "wrong-secret" $token
} -returnCodes error -match glob -result {*verification failed*}

test ns_jwt-hmac-1.5 {verify: tampered payload fails} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice]

    lassign [split $token .] h p s
    set payload [ns_json parse -output triples [ns_base64urldecode $p]]
    lappend payload sub string mallory
    set tampered_payload [ns_base64urlencode -- [ns_json value -type object $payload]]
    set tampered_token "${h}.${tampered_payload}.${s}"

    ns_jwt verify -secret "s3cr3t" $tampered_token
} -returnCodes error -match glob -result {*verification failed*}


# -------------------------------------------------------------------------
# claims in HMAC mode
# -------------------------------------------------------------------------

test ns_jwt-hmac-2.1 {verify: HS256 exp claim accepted when still valid} -body {
    set now [clock seconds]

    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice \
                   -exp [expr {$now + 60}]]

    set verified [ns_jwt verify \
                      -secret "s3cr3t" \
                      -verifyclaims \
                      -now $now \
                      $token]

    list \
        [dict get $verified valid] \
        [dict get [dict get $verified payload] sub]
} -result {1 alice}

test ns_jwt-hmac-2.2 {verify: HS256 exp claim rejected when expired} -body {
    set now [clock seconds]

    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice \
                   -exp [expr {$now - 10}]]

    ns_jwt verify \
        -secret "s3cr3t" \
        -verifyclaims \
        -now $now \
        $token
} -returnCodes error -match glob -result {*expired*}

test ns_jwt-hmac-2.3 {verify: HS256 issuer mismatch fails} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -iss naviserver \
                   -sub alice]

    ns_jwt verify \
        -secret "s3cr3t" \
        -verifyclaims \
        -iss other \
        $token
} -returnCodes error -match glob -result {*issuer mismatch*}

test ns_jwt-hmac-2.4 {verify: HS256 audience list matches expected audience} -body {
    set token [ns_jwt encode \
                   -alg HS256 \
                   -secret "s3cr3t" \
                   -sub alice \
                   -aud {svc1 svc2}]

    set verified [ns_jwt verify \
                      -secret "s3cr3t" \
                      -verifyclaims \
                      -aud svc2 \
                      $token]

    list \
        [dict get $verified valid] \
        [dict get [dict get $verified payload] sub]
} -result {1 alice}

