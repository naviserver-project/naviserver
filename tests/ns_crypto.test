    set pemA [ns_crypto::agreement generate -name X25519]
    set pemB [ns_crypto::agreement generate -name X25519]
    set pubA [ns_crypto::agreement pub -pem $pemA]
    set pubB [ns_crypto::agreement pub -pem $pemB]

    set s1 [ns_crypto::agreement derive -encoding base64url -pem $pemA -peer $pubB]
    set s2 [ns_crypto::agreement derive -encoding base64url -pem $pemB -peer $pubA]

    string equal $s1 $s2
} -result 1

test ns_crypto::agreement-3.4 {derive: X448 roundtrip binary encoding} -constraints {agreement} -body {
    set pemA [ns_crypto::agreement generate -name X448]
    set pemB [ns_crypto::agreement generate -name X448]
    set pubA [ns_crypto::agreement pub -pem $pemA]
    set pubB [ns_crypto::agreement pub -pem $pemB]

    set s1 [ns_crypto::agreement derive -encoding binary -pem $pemA -peer $pubB]
    set s2 [ns_crypto::agreement derive -encoding binary -pem $pemB -peer $pubA]

    list [string length $s1] [string equal $s1 $s2]
} -returnCodes {error ok} -result {56 1}

