    -result {*currently supports only -from public*}


#---------------------------------------------------------------------------
# Generic tests for ns_crypto::key generate
#---------------------------------------------------------------------------

test ns_crypto-key-generate-1.1 {ns_crypto::key generate -name EC -group prime256v1 returns PEM private key} \
    -constraints {keygen ec} \
    -body {
        set pem [ns_crypto::key generate -name EC -group prime256v1]
        expr {
            [string match {*BEGIN PRIVATE KEY*} $pem]
            || [string match {*BEGIN ENCRYPTED PRIVATE KEY*} $pem]
        }
    } \
    -returnCodes {error ok} -result 1

test ns_crypto-key-generate-1.2 {ns_crypto::key generate -name EC -group prime256v1 yields type ec and curve prime256v1} \
    -constraints {keygen ec} \
    -body {
        set pem [ns_crypto::key generate -name EC -group prime256v1]
        set info [ns_crypto::key info -pem $pem]
        list [dict get $info type] [dict get $info curve]
    } \
    -result {ec prime256v1}

test ns_crypto-key-generate-1.3 {ns_crypto::key generate -name EC default -group} \
    -constraints {keygen ec} \
    -body {
        set pem [ns_crypto::key generate -name EC]
        dict get [ns_crypto::key info -pem $pem] curve
    } \
    -returnCodes ok \
    -result {prime256v1}

test ns_crypto-key-generate-1.4 {ns_crypto::key generate -name X25519 works without -group} \
    -constraints {keygen x25519} \
    -body {
        set pem [ns_crypto::key generate -name X25519]
        dict get [ns_crypto::key info -pem $pem] type
    } \
    -result x25519

test ns_crypto-key-generate-1.5 {ns_crypto::key generate -name X25519 accepts matching -group} \
    -constraints {keygen x25519} \
    -body {
        set pem [ns_crypto::key generate -name X25519 -group x25519]
        dict get [ns_crypto::key info -pem $pem] type
    } \
    -result x25519

test ns_crypto-key-generate-1.6 {ns_crypto::key generate -name X25519 rejects wrong -group} \
    -constraints {keygen x25519} \
    -body {
        ns_crypto::key generate -name X25519 -group prime256v1
    } \
    -returnCodes error \
    -match glob \
    -result {*group "*" is not valid*}

test ns_crypto-key-generate-1.7 {ns_crypto::key generate -name RSA rejects unsupported -group} \
    -constraints {keygen} \
    -body {
        ns_crypto::key generate -name RSA -group prime256v1
    } \
    -returnCodes {error ok} \
    -match glob \
    -result {*option "-group" is not supported*}

#---------------------------------------------------------------------------
# SM2 tests for generic key generation and signature sign/verify with -id
#---------------------------------------------------------------------------

test ns_crypto-sm2-1.1 {ns_crypto::key generate -name SM2 returns PEM private key} \
    -constraints {sm2} \
    -body {
        set pem [ns_crypto::key generate -name SM2]
        expr {
            [string match {*BEGIN PRIVATE KEY*} $pem]
            || [string match {*BEGIN ENCRYPTED PRIVATE KEY*} $pem]
        }
    } \
    -result 1


test ns_crypto-sm2-1.2 {ns_crypto::key generate -name SM2 yields type sm2} \
    -constraints {sm2} \
    -body {
        set pem [ns_crypto::key generate -name SM2]
        set info [ns_crypto::key info -pem $pem]
        dict get $info type
    } \
    -result sm2


test ns_crypto-sm2-1.3 {ns_crypto::key generate -name SM2 yields signature capability} \
    -constraints {sm2} \
    -body {
        set pem [ns_crypto::key generate -name SM2]
        set info [ns_crypto::key info -pem $pem]
        list \
            [dict get $info signature] \
            [dict get $info requiresdigest] \
            [dict get $info agreement] \
            [dict get $info kem]
    } \
    -result {1 1 0 0}


test ns_crypto-sm2-1.4 {SM2 sign/verify succeeds with explicit -id} \
    -constraints {sm2 tcl86} \
    -body {
        set pem [ns_crypto::signature generate -name SM2]
        set pub [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -pem $pem -id "alice@example.com" -- "hello world"]
        ns_crypto::signature verify \
            -pem $pub \
            -id "alice@example.com" \
            -signature [binary decode hex $sig] \
            -- "hello world"
    } \
    -result 1


test ns_crypto-sm2-1.5 {SM2 verify fails with different -id} \
    -constraints {sm2 tcl86} \
    -body {
        set pem [ns_crypto::signature generate -name SM2]
        set pub [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -pem $pem -id "alice@example.com" -- "hello world"]
        ns_crypto::signature verify \
            -pem $pub \
            -id "bob@example.com" \
            -signature [binary decode hex $sig] \
            -- "hello world"
    } \
    -result 0


test ns_crypto-sm2-1.6 {SM2 sign/verify succeeds with empty -id} \
    -constraints {sm2 tcl86} \
    -body {
        set pem [ns_crypto::signature generate -name SM2]
        set pub [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -pem $pem -id "" -- "hello world"]
        ns_crypto::signature verify \
            -pem $pub \
            -id "" \
            -signature [binary decode hex $sig] \
            -- "hello world"
    } \
    -returnCodes {error ok} \
    -result "SM2 identifier must not be empty"


test ns_crypto-sm2-1.7 {SM2 sign with unsupported digest sha256 fails when -id is present} \
    -constraints {sm2} \
    -body {
        set pem [ns_crypto::signature generate -name SM2]
        ns_crypto::signature sign -pem $pem -id "alice@example.com" -digest sha256 -- "hello world"
    } \
    -returnCodes error \
    -match glob \
    -result {*invalid digest*}


test ns_crypto-sm2-1.8 {SM2 sign defaults work without explicit -id} \
    -constraints {sm2 tcl86} \
    -body {
        set pem [ns_crypto::signature generate -name SM2]
        set pub [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -pem $pem -- "hello world"]
        ns_crypto::signature verify \
            -pem $pub \
            -signature [binary decode hex $sig] \
            -- "hello world"
    } \
    -result 1


test ns_crypto-sm2-1.9 {non-SM2 signature key rejects -id on sign} \
    -constraints {signature ed25519} \
    -body {
        set pem [ns_crypto::signature generate -name Ed25519]
        ns_crypto::signature sign -pem $pem -id "alice@example.com" -- "hello world"
    } \
    -returnCodes error \
    -match glob \
    -result {*does not support parameter -id*}


test ns_crypto-sm2-1.10 {non-SM2 signature key rejects -id on verify} \
    -constraints {signature ed25519 tcl86} \
    -body {
        set pem [ns_crypto::signature generate -name Ed25519]
        set pub [ns_crypto::signature pub -pem $pem]
        set sig [ns_crypto::signature sign -pem $pem -- "hello world"]
        ns_crypto::signature verify \
            -pem $pub \
            -id "alice@example.com" \
            -signature [binary decode hex $sig] \
            -- "hello world"
    } \
    -returnCodes error \
