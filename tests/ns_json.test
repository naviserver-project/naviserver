#

test ns_json-triples-1.1 {triples: missing subcommand} -body {
    ns_json triples
} -returnCodes error -result {wrong # args: should be "ns_json triples getvalue|setvalue|gettype|schema|match ?/arg .../"}

test ns_json-triples-1.2 {triples: missing subcommand (only 'triples')} -body {
    ns_json triples --
} -returnCodes error -result {ns_json triples: bad subcommand "--": must be getvalue, setvalue, gettype, schema, or match}

test ns_json-triples-1.3 {triples: unknown subcommand} -body {
    ns_json triples doesnotexist
} -returnCodes error -result {ns_json triples: bad subcommand "doesnotexist": must be getvalue, setvalue, gettype, schema, or match}

test ns_json-triples-1.4 {getvalue: missing args} -body {
    ns_json triples getvalue
} -returnCodes error -result {wrong # args: should be "ns_json triples getvalue ?-path /value/? ?-pointer /value/? ?-indices? ?-output json|triples? ?-pretty? ?--? /triples/"}

test ns_json-triples-1.5 {gettype: missing args} -body {
    ns_json triples gettype
} -returnCodes error -result {wrong # args: should be "ns_json triples gettype ?-path /value/? ?-pointer /value/? ?-indices? ?--? /triples/"}

test ns_json-triples-1.6 {setvalue: missing args} -body {
    ns_json triples setvalue
} -returnCodes error -result {wrong # args: should be "ns_json triples setvalue ?-path /value/? ?-pointer /value/? ?-type auto|string|number|boolean|null|object|array? ?--? /triples/ /value/"}

test ns_json-triples-1.7 {getvalue: unknown option} -body {
    ns_json triples getvalue -doesnotexist -path {* a} {a string x}
} -returnCodes error -result {wrong # args: should be "ns_json triples getvalue ?-path /value/? ?-pointer /value/? ?-indices? ?-output json|triples? ?-pretty? ?--? /triples/"}

test ns_json-triples-1.8 {gettype: unknown option} -body {
    ns_json triples gettype -doesnotexist {* a} {a string x}
} -returnCodes error -result {wrong # args: should be "ns_json triples gettype ?-path /value/? ?-pointer /value/? ?-indices? ?--? /triples/"}

test ns_json-triples-1.9 {getvalue: -index still needs path+triples} -body {
    ns_json triples getvalue -index
} -returnCodes error -result {ns_json triples: missing -path or -pointer}

test ns_json-triples-1.10 {gettype: -index still needs path+triples} -body {
    ns_json triples gettype -index
} -returnCodes error -result {ns_json triples: missing -path or -pointer}

test ns_json-triples-1.11 {triples schema: missing triples} -body {
    ns_json triples schema
} -returnCodes error -result {wrong # args: should be "ns_json triples schema ?-pretty? ?-required? ?--? /triples .../"}

test ns_json-triples-1.12 {triples match: missing schema and triples} -body {
    ns_json triples match
} -returnCodes error -result {wrong # args: should be "ns_json triples match -schema /value/ ?-ignoreunsupported? ?--? /triples/"}

#
# --- Basic behavior tests
#

test ns_json-triples-2.0 {getvalue: full tree} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    set j1 [ns_json triples getvalue -path {} $t]
    set j2 [ns_json triples getvalue -pointer "" $t]
    set j3 [ns_json triples getvalue -pointer # $t]
    list $j1 [string equal $j1 $j2] [string equal $j1 $j3]

} -returnCodes {error ok} -result {{{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}} 1 1}

test ns_json-triples-2.1 {getvalue: leaf scalar} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    list \
        [ns_json triples getvalue -path {user name} $t] \
        [ns_json triples getvalue -pointer /user/name $t] \
        [ns_json triples getvalue -pointer #/user/name $t]
} -returnCodes {error ok} -result {{"Alice"} {"Alice"} {"Alice"}}

test ns_json-triples-2.2 {gettype: leaf scalar} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    list \
        [ns_json triples gettype -path {user name} $t] \
        [ns_json triples gettype -pointer /user/name $t]
} -result {string string}

test ns_json-triples-2.3 {getvalue: nested object subtree} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    list \
        [ns_json triples getvalue -path {user flags} $t] \
        [ns_json triples getvalue -pointer /user/flags $t]
} -result {{{"admin":false,"active":true}} {{"admin":false,"active":true}}}

test ns_json-triples-2.4 {gettype: nested object type} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    list \
        [ns_json triples gettype -path {user flags} $t] \
        [ns_json triples gettype -pointer /user/flags $t]
} -result {object object}

test ns_json-triples-2.5 {getvalue -indices: returns usable index path} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    set idx1 [ns_json triples getvalue -indices -path {user flags active} $t]
    set idx2 [ns_json triples getvalue -indices -pointer /user/flags/active $t]
    list \
        [lindex $t {*}$idx1] \
        [lindex $t {*}$idx2] \
        $idx1 $idx2
} -returnCodes {error ok} -result {true true {2 2 8 5} {2 2 8 5}}

test ns_json-triples-2.6 {gettype -indices: returns usable index path} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    set idx1 [ns_json triples gettype -indices -path {user flags active} $t]
    set idx2 [ns_json triples gettype -indices -pointer /user/flags/active $t]
    #ns_log notice idx1 $idx1 idx $idx2
    list \
        [lindex $t {*}$idx1] \
        [lindex $t {*}$idx2]
} -returnCodes {error ok} -result {boolean boolean}

test ns_json-triples-2.7.0 {setvalue: update leaf and re-emit JSON} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]
    set t2 [ns_json triples setvalue -path {user name} $t Bob]
    ns_json value $t2
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Bob","flags":{"admin":false,"active":true}}}}

test ns_json-triples-2.7.1 {setvalue: update leaf and re-emit JSON} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]
    set t2 [ns_json triples setvalue -pointer /user/name $t Bob]
    ns_json value $t2
} -result {{"user":{"id":7,"name":"Bob","flags":{"admin":false,"active":true}}}}

test ns_json-triples-2.8.0 {setvalue: original triples unchanged (functional update)} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]
    set t2 [ns_json triples setvalue -path {user name} $t Bob]
    list \
        [ns_json triples getvalue -output triples -path {user name} $t] \
        [ns_json triples getvalue -output triples -path {user name} $t2]
} -returnCodes {error ok} -result {Alice Bob}

test ns_json-triples-2.8.1 {setvalue: original triples unchanged (functional update)} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]
    set t2 [ns_json triples setvalue -pointer /user/name $t Bob]
    list \
        [ns_json triples getvalue -output triples -pointer /user/name $t] \
        [ns_json triples getvalue -output triples -pointer /user/name $t2]
} -returnCodes {error ok} -result {Alice Bob}

test ns_json-triples-2.9.0 {getvalue: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -path {user doesnotexist} $t
} -returnCodes error -match glob -result {*no such element*}

test ns_json-triples-2.9.1 {getvalue: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -pointer /user/doesnotexist $t
} -returnCodes error -match glob -result {*no such element*}


test ns_json-triples-2.10.0 {gettype: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples gettype -path {user doesnotexist} $t
} -returnCodes error -match glob -result {*no such element*}

test ns_json-triples-2.10.1 {gettype: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples gettype -pointer /user/doesnotexist $t
} -returnCodes error -match glob -result {*no such element*}


test ns_json-triples-2.11.0 {setvalue: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples setvalue -path {user doesnotexist} $t X
} -returnCodes error -match glob -result {*no such element*}

test ns_json-triples-2.11.1 {setvalue: missing path element errors} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples setvalue -pointer /user/doesnotexist $t X
} -returnCodes error -match glob -result {*no such element*}

#
# --- ns_json triples setvalue with containers
#
test ns_json-triples-3.0 {getvalue/setvalue: subtree roundtrip via -output triples} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t    [ns_json parse -output triples $json]

    # Extract subtree (object) as triples list (should be unwrapped VALUE).
    set flags [ns_json triples getvalue -output triples -pointer /user/flags $t]

    # Replace the whole flags subtree (no structural change, just roundtrip).
    set t2 [ns_json triples setvalue -path {user flags} $t $flags]
    ns_json value $t2
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}

test ns_json-triples-3.1 {setvalue: replace subtree with modified extracted triples} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t    [ns_json parse -output triples $json]

    # Extract subtree (object) as triples list.
    set flags [ns_json triples getvalue -output triples -pointer /user/flags $t]

    # Update leaf inside extracted subtree, then splice back.
    set flags2 [ns_json triples setvalue -path {active} $flags false]
    set t2     [ns_json triples setvalue -path {user flags} $t $flags2]

    ns_json value $t2
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":false}}}}

test ns_json-triples-3.2 {setvalue: replace subtree with scalar value and emit JSON} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t    [ns_json parse -output triples $json]

    # Replace an object subtree with a scalar.
    set t2 [ns_json triples setvalue -type null -path {user flags} $t ""]
    ns_json value $t2
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Alice","flags":null}}}

test ns_json-triples-3.3 {setvalue: splice extracted scalar and preserve type via explicit -type} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t   [ns_json parse -output triples $json]

    # Extract scalar as triples output (raw scalar value).
    set name [ns_json triples getvalue -output triples -pointer /user/name $t]

    # Splice it into a different leaf, forcing a numeric type conversion should error.
    # (use a safe splice first)
    set t2 [ns_json triples setvalue -path {user name} $t $name]
    ns_json value $t2
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}

test ns_json-triples-3.4 {setvalue: inserting wrapped triples unwraps (no "" key)} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]

    # Insert a wrapped triples document as a subtree. setvalue must unwrap it
    # (insert VALUE, not the wrapper), otherwise the result would contain a \"\" key.
    set t2  [ns_json triples setvalue -path {user flags} $t $t]
    list \
        [ns_json value $t2] \
        [string match {*\"\":*} [ns_json value $t2]]
} -returnCodes {error ok} -result {{{"user":{"id":7,"name":"Alice","flags":{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}}} 0}


test ns_json-triples-3.5 {getvalue root -output json: returns whole document} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t   [ns_json parse -output triples $json]
    ns_json triples getvalue -output json -pointer "" $t
} -returnCodes {error ok} -result {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}

test ns_json-triples-3.6 {setvalue: inserting wrapped triples as subtree does not create "" key} -body {
    set json {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}
    set t [ns_json parse -output triples $json]

    # First insertion: place the whole document under user/flags.
    set t2  [ns_json triples setvalue -path {user flags} $t $t]

    # Second insertion: place t2 again under user/flags (this used to embed the
    # root wrapper and create an empty-string key \"\" in the JSON output).
    set t3  [ns_json triples setvalue -path {user flags} $t $t2]

    # Assert: JSON output must not contain an object member with empty key.
    list \
        [string match {*\"\":*} [ns_json value -pretty $t3]] \
        [string match {*\"\":*} [ns_json value $t3]]

} -returnCodes {error ok} -result {0 0}

#
# --- Boundary cases for -pointer (RFC 6901)
#

test ns_json-triples-pointer-1.1 {-pointer: empty string maps to the full tree} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -pointer "" $t
} -returnCodes {error ok} -match glob -result {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}

test ns_json-triples-pointer-1.2 {-pointer: must start with '/'} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -pointer "user/name" $t
} -returnCodes error -match glob -result {*invalid JSON pointer*start with*/*}

test ns_json-triples-pointer-1.3 {-pointer: root member access} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -output triples -pointer /user/name $t
} -result {Alice}

test ns_json-triples-pointer-1.4 {-pointer: nested boolean} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples getvalue -pointer /user/flags/active $t
} -result {true}

test ns_json-triples-pointer-1.5 {-pointer: gettype} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    ns_json triples gettype -pointer /user/flags/active $t
} -result {boolean}

test ns_json-triples-pointer-1.6 {-pointer: -indices returns usable index list} -body {
    set t [ns_json parse -output triples {{"user":{"id":7,"name":"Alice","flags":{"admin":false,"active":true}}}}]
    set idx [ns_json triples getvalue -indices -pointer "/user/flags/active" $t]
    lindex $t {*}$idx
} -result {true}

test ns_json-triples-pointer-1.7 {-pointer: ~1 unescapes to '/'} -body {
    # Create a triples list with a key containing '/' and access it via pointer.
    set t {a/b string X}
    ns_json triples getvalue -output triples -pointer "/a~1b" $t
} -result {X}

test ns_json-triples-pointer-1.8 {-pointer: ~0 unescapes to '~'} -body {
    set t {a~b string X}
    ns_json triples getvalue -output triples  -pointer "/a~0b" $t
} -result {X}

test ns_json-triples-pointer-1.9 {-pointer: invalid escape '~' at end of segment} -body {
    set t {a string X}
    ns_json triples getvalue -pointer "/a~" $t
} -returnCodes error -match glob -result {*invalid JSON pointer escape*}

test ns_json-triples-pointer-1.10 {-pointer: invalid escape '~2' (reserved for keypath only)} -body {
    set t {a.b string X}
    ns_json triples getvalue -pointer "/a~2b" $t
} -returnCodes error -match glob -result {*invalid JSON pointer escape*}

test ns_json-triples-pointer-1.11 {-pointer: invalid escape '~x'} -body {
    set t {axb string X}
    ns_json triples getvalue -pointer "/a~xb" $t
} -returnCodes error -match glob -result {*invalid JSON pointer escape*}


test ns_json-triples-pointer-1.12a {-pointer: empty segment via '/' (key is empty string)} -body {
    # RFC 6901: consecutive slashes produce an empty reference token.
    set t {"" object {"" string E}}
    ns_json triples getvalue -output triples -pointer "/" $t
} -returnCodes {error ok} -result {E}

test ns_json-triples-pointer-1.12b {-pointer: empty segment via '//' (key is empty string)} -body {
    # RFC 6901: consecutive slashes produce an empty reference token.
    set t {{} object {"" object {"" string E}}}
    ns_json triples getvalue -output triples -pointer "//" $t
} -returnCodes {error ok} -result {E}

test ns_json-triples-pointer-1.13 {-pointer: empty segment in middle (key is empty string)} -body {
    # /user//name refers to key "" under user.
    set t {user object {"" object {name string E}}}
    ns_json triples getvalue -pointer "/user//name" $t
} -result {"E"}

test ns_json-triples-pointer-1.14 {-pointer: trailing slash selects empty-key member at leaf} -body {
    set t {user object {"" string E}}
    ns_json triples getvalue -pointer "/user/" $t
} -result {"E"}


test ns_json-triples-contract-5.2 {ns_json value rejects non-triples container content for object} -body {
    # object "o" has value list of length 2 -> invalid
    set bad {o object {k string}}
    ns_json value -type object $bad
} -returnCodes error -match glob -result {*length*3*}

test ns_json-triples-contract-5.3 {ns_json value accepts empty container content for object} -body {
    set ok {o object {}}
    ns_json value -type object $ok
} -returnCodes ok -result {{"o":{}}}

test ns_json-triples-contract-5.4 {ns_json value accepts empty container content for array} -body {
    set ok {a array {}}
    ns_json value -type object $ok
} -returnCodes ok -result {{"a":[]}}

#
# --- "ns_json triples schema"
#

test ns_json-triples-schema-1.0 "schema: array of objects with nullable field" -body {
    set json {{
      "users": [
        {"id": 1, "name": "Alice", "active": true},
        {"id": 2, "name": "Bob",   "active": false},
        {"id": 3, "name": "Eve",   "active": null}
      ],
      "count": 3
    }}
    set t [ns_json parse -output triples $json]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"count":{"type":"number"},"users":{"type":"array","items":{"type":"object","properties":{"active":{"type":["boolean","null"]},"id":{"type":"number"},"name":{"type":"string"}}}}}}}

test ns_json-triples-schema-1.1 "schema: mixed scalar array uses compact type union" -body {
    set t [ns_json parse -output triples {[true,null]}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"array","items":{"type":["boolean","null"]}}}

test ns_json-triples-schema-1.2 "schema: scalar root" -body {
    set t [ns_json parse -output triples {"x"}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"string"}}

test ns_json-triples-schema-1.3 "schema: mixed scalar array uses compact type union" -body {
    set t [ns_json parse -output triples {[true,null]}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"array","items":{"type":["boolean","null"]}}}

test ns_json-triples-schema-1.4 "schema: object properties are canonicalized" -body {
    set t [ns_json parse -output triples {{"z":1,"a":2,"m":3}}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"a":{"type":"number"},"m":{"type":"number"},"z":{"type":"number"}}}}

test ns_json-triples-schema-1.5 "schema: empty array" -body {
    set t [ns_json parse -output triples {[]}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"array","items":{}}}

test ns_json-triples-schema-1.6 "schema -required: stable required order" -body {
    set t [ns_json parse -output triples {{"z":1,"a":2}}]
    ns_json triples schema -required $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"a":{"type":"number"},"z":{"type":"number"}},"required":["a","z"]}}

test ns_json-triples-schema-1.7 "schema: empty object" -body {
    set t [ns_json parse -output triples {{}}]
    ns_json triples schema $t
} -returnCodes {error ok} -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{}}}


#
# --- "ns_json triples schema" + merge + required
#
test ns_json-triples-schema-merge-1.1 \
    "schema merge of multiple objects without -required omits required" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}}}}

test ns_json-triples-schema-merge-1.2 \
    "schema merge of multiple objects with -required uses intersection semantics" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"email":"c@example.com"}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}},"required":["id"]}}

test ns_json-triples-schema-merge-1.3 \
    "schema merge with -required keeps all properties required when present in every instance" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2,"email":"b@example.com"}}]

        ns_json triples schema -required $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}},"required":["email","id"]}}

test ns_json-triples-schema-merge-1.4 \
    "schema merge across multiple instances compacts scalar type unions per property" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2,"email":null}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":["null","string"]},"id":{"type":"number"}}}}

test ns_json-triples-schema-merge-1.5 \
    "schema merge with -required and nullable property keeps property required when present in every instance" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2,"email":null}}]

        ns_json triples schema -required $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":["null","string"]},"id":{"type":"number"}},"required":["email","id"]}}


test ns_json-triples-schema-merge-1.6 \
    "schema merge across multiple instances unions property type when property appears only in some documents" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"email":null}}]

        ns_json triples schema $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":["null","string"]},"id":{"type":"number"}}}}

test ns_json-triples-schema-merge-1.7 \
    "schema merge with -required drops property missing from one instance even when types merge compactly" -body {
        set t1 [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"email":null}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"email":{"type":["null","string"]},"id":{"type":"number"}},"required":["id"]}}

test ns_json-triples-schema-merge-1.8 \
    "schema merge of optional property with differing scalar types produces compact type union" -body {
        set t1 [ns_json parse -output triples {{"id":1,"flag":true}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"flag":"yes"}}]

        ns_json triples schema $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"flag":{"type":["boolean","string"]},"id":{"type":"number"}}}}

test ns_json-triples-schema-merge-1.9 \
    "schema merge with -required drops optional property whose scalar types differ across instances" -body {
        set t1 [ns_json parse -output triples {{"id":1,"flag":true}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"flag":"yes"}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"flag":{"type":["boolean","string"]},"id":{"type":"number"}},"required":["id"]}}

test ns_json-triples-schema-merge-1.10 \
    "schema merge with -required keeps mixed-type property required when present in every instance" -body {
        set t1 [ns_json parse -output triples {{"id":1,"flag":true}}]
        set t2 [ns_json parse -output triples {{"id":2,"flag":"yes"}}]

        ns_json triples schema -required $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"flag":{"type":["boolean","string"]},"id":{"type":"number"}},"required":["flag","id"]}}

test ns_json-triples-schema-merge-1.11 \
    "schema merge with -required drops property seen in only one of several instances" -body {
        set t1 [ns_json parse -output triples {{"id":1,"nickname":"joe"}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"},"nickname":{"type":"string"}},"required":["id"]}}

test ns_json-triples-schema-merge-1.12 \
    "schema merge of nested object without -required omits nested required" -body {
        set t1 [ns_json parse -output triples {{"user":{"id":1,"email":"a@example.com"}}}]
        set t2 [ns_json parse -output triples {{"user":{"id":2}}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"user":{"type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}}}}}}

test ns_json-triples-schema-merge-1.13 \
    "schema merge of nested object with -required uses nested intersection semantics" -body {
        set t1 [ns_json parse -output triples {{"user":{"id":1,"email":"a@example.com"}}}]
        set t2 [ns_json parse -output triples {{"user":{"id":2}}}]
        set t3 [ns_json parse -output triples {{"user":{"id":3,"email":"c@example.com"}}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"user":{"type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}},"required":["id"]}},"required":["user"]}}

test ns_json-triples-schema-merge-1.14 \
    "schema merge with -required drops top-level property missing in one instance and nested required is intersected independently" -body {
        set t1 [ns_json parse -output triples {{"user":{"id":1,"email":"a@example.com"}}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"user":{"id":3}}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"},"user":{"type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}},"required":["id"]}}}}

test ns_json-triples-schema-merge-1.15 \
    "schema merge of arrays with differing scalar item types produces compact item type union" -body {
        set t1 [ns_json parse -output triples {{"tags":["a","b"]}}]
        set t2 [ns_json parse -output triples {{"tags":[1,2]}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"tags":{"type":"array","items":{"type":["number","string"]}}}}}

test ns_json-triples-schema-merge-1.16 \
    "schema merge of arrays with null and string items produces compact nullable item type union" -body {
        set t1 [ns_json parse -output triples {{"tags":["a"]}}]
        set t2 [ns_json parse -output triples {{"tags":[null]}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"tags":{"type":"array","items":{"type":["null","string"]}}}}}

test ns_json-triples-schema-merge-1.17 \
    "schema merge with -required keeps array property required when present in every instance" -body {
        set t1 [ns_json parse -output triples {{"id":1,"tags":["a"]}}]
        set t2 [ns_json parse -output triples {{"id":2,"tags":[1]}}]

        ns_json triples schema -required $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"},"tags":{"type":"array","items":{"type":["number","string"]}}},"required":["id","tags"]}}

test ns_json-triples-schema-merge-1.18 \
    "schema merge with -required drops array property missing in one instance" -body {
        set t1 [ns_json parse -output triples {{"id":1,"tags":["a"]}}]
        set t2 [ns_json parse -output triples {{"id":2}}]
        set t3 [ns_json parse -output triples {{"id":3,"tags":[1]}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"},"tags":{"type":"array","items":{"type":["number","string"]}}},"required":["id"]}}


test ns_json-triples-schema-merge-1.19 \
    "schema merge with -required intersects required properties in object-valued array items" -body {
        set t1 [ns_json parse -output triples {{"users":[{"id":1,"email":"a@example.com"}]}}]
        set t2 [ns_json parse -output triples {{"users":[{"id":2}]}}]
        set t3 [ns_json parse -output triples {{"users":[{"id":3,"email":"c@example.com"}]}}]

        ns_json triples schema -required $t1 $t2 $t3
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"users":{"type":"array","items":{"type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}},"required":["id"]}}},"required":["users"]}}

test ns_json-triples-schema-merge-1.20 \
    "schema merge of object-valued array items without -required omits nested required" -body {
        set t1 [ns_json parse -output triples {{"users":[{"id":1,"email":"a@example.com"}]}}]
        set t2 [ns_json parse -output triples {{"users":[{"id":2}]}}]

        ns_json triples schema $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"users":{"type":"array","items":{"type":"object","properties":{"email":{"type":"string"},"id":{"type":"number"}}}}}}}

test ns_json-triples-schema-merge-1.21 \
    "schema merge with -required omits empty required after top-level intersection becomes empty" -body {
        set t1 [ns_json parse -output triples {{"user":{"id":1}}}]
        set t2 [ns_json parse -output triples {{"id":2}}]

        ns_json triples schema -required $t1 $t2
    } -result {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"},"user":{"type":"object","properties":{"id":{"type":"number"}},"required":["id"]}}}}


#
# --- "ns_json triples match"
#
test ns_json-triples-match-1.1 {match: simple object schema succeeds} -body {
    set t [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
    set s [ns_json triples schema -required $t]

    ns_json triples match -schema $s $t
} -result 1

test ns_json-triples-match-1.2 {match: missing required property fails} -body {
    set tref [ns_json parse -output triples {{"id":1,"email":"a@example.com"}}]
    set t    [ns_json parse -output triples {{"email":"a@example.com"}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /: missing required property "id"}

test ns_json-triples-match-1.3 {match: wrong scalar type fails} -body {
    set tref [ns_json parse -output triples {{"id":1}}]
    set t    [ns_json parse -output triples {{"id":"1"}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /id: expected number, got string}

test ns_json-triples-match-1.4 {match: unexpected property fails} -body {
    set tref [ns_json parse -output triples {{"id":1}}]
    set t    [ns_json parse -output triples {{"id":1,"extra":true}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /extra: property not allowed by schema}

test ns_json-triples-match-1.5 {match: nullable union accepts null} -body {
    set t1 [ns_json parse -output triples {{"email":"a@example.com"}}]
    set t2 [ns_json parse -output triples {{"email":null}}]
    set s  [ns_json triples schema $t1 $t2]

    ns_json triples match -schema $s $t2
} -result 1

test ns_json-triples-match-1.6 {match: nullable union rejects wrong type} -body {
    set t1 [ns_json parse -output triples {{"email":"a@example.com"}}]
    set t2 [ns_json parse -output triples {{"email":null}}]
    set t3 [ns_json parse -output triples {{"email":{}}}]
    set s  [ns_json triples schema $t1 $t2]

    ns_json triples match -schema $s $t3
} -returnCodes error -match glob -result {ns_json: schema mismatch at /email: *}

test ns_json-triples-match-1.7 {match: array item type succeeds} -body {
    set tref [ns_json parse -output triples {{"tags":["a","b"]}}]
    set t    [ns_json parse -output triples {{"tags":["x","y"]}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -result 1

test ns_json-triples-match-1.8 {match: array item type mismatch fails} -body {
    set tref [ns_json parse -output triples {{"tags":["a","b"]}}]
    set t    [ns_json parse -output triples {{"tags":["x",1]}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /tags/1: expected string, got number}

test ns_json-triples-match-1.9 {match: nested object succeeds} -body {
    set tref [ns_json parse -output triples {{"user":{"id":1,"email":"a@example.com"}}}]
    set t    [ns_json parse -output triples {{"user":{"id":2,"email":"b@example.com"}}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -result 1

test ns_json-triples-match-1.10 {match: nested object missing required fails} -body {
    set tref [ns_json parse -output triples {{"user":{"id":1,"email":"a@example.com"}}}]
    set t    [ns_json parse -output triples {{"user":{"email":"b@example.com"}}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /user: missing required property "id"}

test ns_json-triples-match-1.11 {match: unsupported schema keyword rejected by default} -body {
    set t [ns_json parse -output triples {{"id":1}}]
    set s {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"}},"additionalProperties":false}}

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: unsupported schema keyword "additionalProperties"}

test ns_json-triples-match-1.12 {match: unsupported schema keyword ignored with -ignoreunsupported} -body {
    set t [ns_json parse -output triples {{"id":1}}]
    set s {{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"type":"number"}},"additionalProperties":false}}

    ns_json triples match -ignoreunsupported -schema $s $t
} -result 1


test ns_json-triples-match-2.1 {match: nested array mismatch path} -body {
    set tref [ns_json parse -output triples {{"a":[{"id":1},{"id":2}]}}]
    set t    [ns_json parse -output triples {{"a":[{"id":1},{"id":"x"}]}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /a/1/id:*}

test ns_json-triples-match-2.2 {match: path escaping in error} -body {
    set tref [ns_json parse -output triples {{"a/b":1}}]
    set t    [ns_json parse -output triples {{"a/b":"x"}}]
    set s [ns_json triples schema -required $tref]

    ns_json triples match -schema $s $t
} -returnCodes error -match glob -result {ns_json: schema mismatch at /a~1b:*}

test ns_json-triples-match-2.3 {match: anyOf branch success} -body {
    set t1 [ns_json parse -output triples {{"x":1}}]
    set t2 [ns_json parse -output triples {{"x":"a"}}]

    set s [ns_json triples schema $t1 $t2]

    ns_json triples match -schema $s $t2
} -result 1

test ns_json-triples-match-2.4 {match: anyOf branch failure} -body {
    set t1 [ns_json parse -output triples {{"x":1}}]
    set t2 [ns_json parse -output triples {{"x":"a"}}]
    set t3 [ns_json parse -output triples {{"x":{}}}]

    set s [ns_json triples schema $t1 $t2]

    ns_json triples match -schema $s $t3
} -returnCodes error -match glob -result {ns_json: schema mismatch at /x:*}

test ns_json-triples-match-2.5 {match: schema without required} -body {
    set t [ns_json parse -output triples {{"id":1}}]

    set s {{"type":"object","properties":{"id":{"type":"number"}}}}

    ns_json triples match -schema $s $t
} -result 1

test ns_json-triples-match-2.6 {match: nested unsupported keyword ignored} -body {
    set t [ns_json parse -output triples {{"id":1}}]

    set s {{"type":"object",
            "properties":{"id":{"type":"number","minimum":0}}}}

    ns_json triples match -ignoreunsupported -schema $s $t
} -result 1

# --- cleanup ---------------------------------------------------------------

cleanupTests
return
