test ns_adp-tagset-request-1.13 {include with unknown tagset fails} -constraints {serverListen} -setup {
    set ::ns_adp_test_fragment_unknown [file join [ns_server pagedir] adp-tagset-fragment-unknown.adp]
    set fp [open $::ns_adp_test_fragment_unknown w]
    puts $fp {plain}
    close $fp

    ns_register_proc GET /adp-tagset-include-unknown {
        set result [ns_adp_parse -string [ns_trim -delimiter | {
            |    <%
            |        set code [catch {
            |            ns_adp_include -tagset does-not-exist adp-tagset-fragment-unknown.adp
            |        } errorMsg]
            |        ns_adp_puts -nonewline [list $code $errorMsg]
            |    %>
        }]]

        ns_return 200 text/plain [string trim $result]
    }
} -body {
    nstest::http -getbody 1 GET /adp-tagset-include-unknown
} -cleanup {
    ns_unregister_op GET /adp-tagset-include-unknown
    file delete -force $::ns_adp_test_fragment_unknown
