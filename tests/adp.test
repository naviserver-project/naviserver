############################################################################
# ns_adp_include
############################################################################
test ns_adp_include-1.0 {syntax: ns_adp_include} -body {
    ns_adp_include
} -returnCodes error -result {wrong # args: should be "_ns_adp_include ?-cache /time/? ?-nocache? ?-tagset /value/? ?-tcl? ?--? /filename/ ?/arg .../?"}
# ns_adp_include is a Tcl proc: message should be {wrong # args: should be "ns_adp_include ?-cache /time/? ?-nocache? ?-tagset /value/? ?-tcl? ?--? /filename/ ?/arg .../?"}

test ns_adp_include-1.1 {adp2 uses ns_adp_include includes b.adp and passes argv to included adp} -constraints {serverListen} -body {
    nstest::http -getbody 1 GET /adp2.adp
} -match glob -result {*Hello, world*ns_adp_argc: 7*ns_adp_argv: 1 2 3 a A z Z*ns_adp_argv 0: 1*ns_adp_argv 10 DEFAULT DEFAULT*1, 2, 3, a, A, z, Z*end*end*}


############################################################################
# ns_adp_registeradp
############################################################################

test ns_adp_registeradp-2.1 {registeradp with adp-markup, no attributes, no ending tag} -body {
    ns_adp_registeradp regadp {The current server is '<% ns_adp_puts -nonewline [ns_info server] %>'.}
    ns_adp_parse -string {start <b>x <regadp> y</b> end}
} -result {start <b>x the current server is 'test'. y</b> end}

test ns_adp_registeradp-2.2 {registeradp with adp-markup, attributes, no ending tag} -body {
    ns_adp_registeradp regadp {The current server is '<% ns_adp_puts -nonewline [ns_info server] %>'.}
    # Attributes (a=1 b=2) are swallowed
    ns_adp_parse -string {start <b>x <regadp a=1 b=2> y</b> end}
} -result {start <b>x the current server is 'test'. y</b> end}

test ns_adp_registeradp-2.3 {registeradp with adp-markup, no attributes, ending tag} -body {
    ns_adp_registeradp regadp /regadp {The current server is '<% ns_adp_puts -nonewline [ns_info server] %>'.}
    # Content between opening and closing tag (" y ") is swallowed
    ns_adp_parse -string {start <b>x <regadp> y </regadp> z </b> end}
} -result {start <b>x the current server is 'test'. z </b> end}

test ns_adp_registeradp-2.4 {registeradp with adp-markup, attributes, ending tag} -body {
    ns_adp_registeradp regadp  /regadp {The current server is '<% ns_adp_puts -nonewline [ns_info server] %>'.}
    # Attributes (a=1 b=2) are swallowed
    # Content between opening and closing tag (" y ") is swallowed
    ns_adp_parse -string {start <b>x <regadp a="1" b=2> y </regadp> z </b> end}
} -result {start <b>x the current server is 'test'. z </b> end}


test ns_adp_registeradp-3.1 {registeradp with adp-file} -body {
    ns_adp_registeradp regadp {<% ns_adp_include adp2.adp A B C %>}
    ns_adp_parse -string {start <b>x <regadp a=1> y</b> end}
} -returnCodes {error ok} -match glob -result {start <b>x*argv: 1 2 3 a A z Z*end*}


test ns_adp_registeradp-4.0 {whitespace handling between adp tags} -body {
    proc ::adp_button_handler {string attributes} {
        #ns_log warning HANDLER $string $attributes;
        return "<button>$string</button>"
    }
    ns_adp_registerscript adp:button /adp:button ::adp_button_handler
    set text [ns_trim -delimiter | {
            |  a
            |  <adp:button>hello</adp:button>
            |  <adp:button>second button</adp:button>
            |  b
    }]
    ns_adp_parse -string $text
} -cleanup {
    rename ::adp_button_handler ""
    unset -nocomplain text expected
} -returnCodes {error ok} -match glob -result [ns_trim -delimiter | {
    |  a
    |  <button>hello</button>
    |  <button>second button</button>
    |  b
}]

test ns_adp_registeradp-4.1 {whitespace handling between adp tags} -body {
    proc ::adp_button_handler {string attributes} {return "<button>$string</button>"}
    ns_adp_registerscript adp:button /adp:button ::adp_button_handler
    set text {
        text1
        <adp:button>1</adp:button> <adp:button>2</adp:button>
        <adp:button>3</adp:button>
        <button>4</button> <button>5</button>
        <button>6</button>
        text2
    }
    set expected [ns_trim -delimiter | {
            |  a
            |  <button>hello</button>
            |  <button>second button</button>
            |  b
    }]
    ns_adp_parse -string [ns_trim -delimiter | {
        |  text1
        |  <adp:button>1</adp:button> <adp:button>2</adp:button>
        |  <adp:button>3</adp:button>
        |  <button>4</button> <button>5</button>
        |  <button>6</button>
        |  text2
    }]
} -cleanup {
    rename ::adp_button_handler ""
    unset -nocomplain text expected
} -returnCodes {error ok} -match glob -result [ns_trim -delimiter | {
    |  text1
    |  <button>1</button> <button>2</button>
    |  <button>3</button>
    |  <button>4</button> <button>5</button>
    |  <button>6</button>
    |  text2
}]

############################################################################
# ns_adp_tagset creation
############################################################################
test ns_adp-tagset-1.0.1 {syntax ns_adp_tagset create} -body {
    ns_adp_tagset create
} -returnCodes error -result {wrong # args: should be "ns_adp_tagset create ?-fallback /value/? /name/"}

test ns_adp-tagset-1.0.2 {syntax ns_adp_tagset exists} -body {
    ns_adp_tagset exists
} -returnCodes error -result {wrong # args: should be "ns_adp_tagset exists /name/"}

test ns_adp-tagset-1.0.3 {syntax ns_adp_tagset names} -body {
    ns_adp_tagset names x
} -returnCodes error -result {wrong # args: should be "ns_adp_tagset names"}

test ns_adp-tagset-1.0.4 {syntax ns_adp_tagset info} -body {
    ns_adp_tagset info
} -returnCodes error -result {wrong # args: should be "ns_adp_tagset info /name/"}


test ns_adp-tagset-1.1 {default tagset exists} -body {
    ns_adp_tagset exists default
} -result 1

test ns_adp-tagset-1.2 {create isolated tagset} -body {
    ns_adp_tagset create test-isolated
    ns_adp_tagset exists test-isolated
} -result 1

test ns_adp-tagset-1.3 {create tagset with fallback} -body {
    ns_adp_tagset create -fallback default test-fallback
    dict get [ns_adp_tagset info test-fallback] fallback
} -result default

test ns_adp-tagset-1.4 {tagset names includes default and created tagsets} -body {
    set names [ns_adp_tagset names]
    expr {"default" in $names
          && "test-isolated" in $names
          && "test-fallback" in $names}
} -result 1

test ns_adp-tagset-1.5 {cannot create reserved default tagset} -body {
    ns_adp_tagset create default
} -returnCodes error -match glob -result {*reserved*}

test ns_adp-tagset-1.6 {cannot create duplicate tagset} -body {
    ns_adp_tagset create test-isolated
} -returnCodes error -match glob -result {*already exists*}

test ns_adp-tagset-1.7 {unknown fallback rejected} -body {
    ns_adp_tagset create -fallback other test-other
} -returnCodes error -match glob -result {*unknown ADP tagset fallback*}

############################################################################
# ns_adp_tagset introspection
############################################################################

test ns_adp-tagset-1.8 {tagset exists returns false for unknown tagset} -body {
    ns_adp_tagset exists does-not-exist
} -result 0

test ns_adp-tagset-1.9 {tagset names includes default} -body {
    expr {"default" in [ns_adp_tagset names]}
} -result 1

test ns_adp-tagset-1.10 {tagset names includes newly created tagset} -body {
    ns_adp_tagset create adp-test-names
    expr {"adp-test-names" in [ns_adp_tagset names]}
} -result 1

test ns_adp-tagset-1.11 {tagset info default returns size and empty fallback} -body {
    set info [ns_adp_tagset info default]
    list \
        [dict exists $info size] \
        [dict get $info fallback]
} -result {1 {}}

test ns_adp-tagset-1.12 {tagset info isolated tagset returns size zero and empty fallback} -body {
    ns_adp_tagset create adp-test-info-isolated
    set info [ns_adp_tagset info adp-test-info-isolated]
    list \
        [dict get $info size] \
        [dict get $info fallback]
} -result {0 {}}

test ns_adp-tagset-1.13 {tagset info fallback tagset reports default fallback} -body {
    ns_adp_tagset create -fallback default adp-test-info-fallback
    set info [ns_adp_tagset info adp-test-info-fallback]
    list \
        [dict get $info size] \
        [dict get $info fallback]
} -result {0 default}

test ns_adp-tagset-1.14 {tagset info size changes after registering tag} -setup {
    ns_adp_tagset create adp-test-info-size
    proc ::__adp_tag_info_size {body set} {
        return SIZE
    }
} -body {
    set before [dict get [ns_adp_tagset info adp-test-info-size] size]
    ns_adp_registerscript -tagset adp-test-info-size infosize /infosize ::__adp_tag_info_size
    set after [dict get [ns_adp_tagset info adp-test-info-size] size]
    list $before $after
} -cleanup {
    rename ::__adp_tag_info_size ""
} -result {0 1}

test ns_adp-tagset-1.15 {tagset info unknown tagset fails} -body {
    ns_adp_tagset info does-not-exist
} -returnCodes error -match glob -result {*ADP tagset*does-not-exist*does not exist*}

############################################################################
# ns_adp_tagset registration of tags
############################################################################

test ns_adp-tagset-2.1 {register script tag in named tagset} -setup {
    ns_adp_tagset create adp-test-tags
    proc ::__adp_tag_hello {body set} {
        return "HELLO"
    }
} -body {
    ns_adp_registerscript -tagset adp-test-tags hello /hello ::__adp_tag_hello
    dict get [ns_adp_tagset info adp-test-tags] size
} -cleanup {
    rename ::__adp_tag_hello ""
} -result 1

test ns_adp-tagset-2.2 {registering same tag in named tagset replaces previous definition} -setup {
    ns_adp_tagset create adp-test-replace
    proc ::__adp_tag_one {body set} {
        return ONE
    }
    proc ::__adp_tag_two {body set} {
        return TWO
    }
} -body {
    ns_adp_registerscript -tagset adp-test-replace x /x ::__adp_tag_one
    ns_adp_registerscript -tagset adp-test-replace x /x ::__adp_tag_two
    dict get [ns_adp_tagset info adp-test-replace] size
} -cleanup {
    rename ::__adp_tag_one ""
    rename ::__adp_tag_two ""
} -result 1

test ns_adp-tagset-2.3 {registering tag in unknown tagset fails} -body {
    ns_adp_registerscript -tagset does-not-exist x /x ::some_proc
} -returnCodes error -match glob -result {*ADP tagset*does-not-exist*}

test ns_adp-tagset-2.4 {registering tag in default remains supported} -setup {
    proc ::__adp_tag_default {body set} {
        return DEFAULT
    }
} -body {
    ns_adp_registerscript defaulttag /defaulttag ::__adp_tag_default
    expr {[dict get [ns_adp_tagset info default] size] > 0}
} -cleanup {
    rename ::__adp_tag_default ""
} -result 1

############################################################################
# ns_adp_tagset parsing with named tagsets
############################################################################
test ns_adp-tagset-3.1 {named tagset recognizes its own registered tag} -setup {
    ns_adp_tagset create adp-test-use
    proc ::__adp_tag_named {body set} {
        return "NAMED:[ns_adp_parse -string $body]"
    }
    ns_adp_registerscript -tagset adp-test-use named /named ::__adp_tag_named
} -body {
    ns_adp_parse -tagset adp-test-use -string {before <named>body</named> after}
} -cleanup {
    rename ::__adp_tag_named ""
} -result {before NAMED:body after}

test ns_adp-tagset-3.2 {tag from isolated named tagset is not visible in default tagset} -setup {
    ns_adp_tagset create adp-test-isolated
    proc ::__adp_tag_isolated {body set} {
        return "ISOLATED"
    }
    ns_adp_registerscript -tagset adp-test-isolated isolated /isolated ::__adp_tag_isolated
} -body {
