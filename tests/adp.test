    ns_adp_registerproc "" _test_adp_tag_proc
} -returnCodes error -match glob -result {invalid start tag:*}

test ns_adp_registerproc-3.5 {reject registered ADP tag name starting with dollar} -body {
    ns_adp_registerproc "\$foo" _test_adp_tag_proc
} -returnCodes error -match glob -result {invalid start tag:*}

