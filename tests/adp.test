    ns_adp_registerproc "@foo" _test_adp_tag_proc
} -returnCodes error -match glob -result {invalid start tag:*}

test ns_adp_registerproc-3.8 {reject registered ADP tag name starting with underscore} -body {
    ns_adp_registerproc "_foo" _test_adp_tag_proc
} -returnCodes error -match glob -result {invalid start tag:*}

test ns_adp_registerproc-3.9 {reject registered ADP tag name containing ampersand} -body {
    ns_adp_registerproc "foo&bar" _test_adp_tag_proc
} -returnCodes error -match glob -result {invalid start tag:*}

test ns_adp_registerproc-3.10 {reject registered ADP tag name containing whitespace} -body {
    ns_adp_registerproc "foo bar" _test_adp_tag_proc
