test ns_adp-tagset-request-1.1 {include can use explicit tagset override} -constraints {serverListen} -setup {
    ns_adp_tagset create adp-test-include

    ns_adp_registerscript itag /itag ::__adp_tag_include_default
    ns_adp_registerscript -tagset adp-test-include itag /itag ::__adp_tag_include_named

    set ::ns_adp_test_fragment [file join [ns_server pagedir] adp-tagset-fragment.adp]
    set fp [open $::ns_adp_test_fragment w]
    puts $fp {<itag>x</itag>}
    close $fp

    ns_register_proc GET /adp-tagset-include {
        proc ::__adp_tag_include_default {body set} {
            return DEFAULT
        }
        proc ::__adp_tag_include_named {body set} {
            return NAMED
        }

        #set direct [ns_adp_parse -tagset adp-test-include -file adp-tagset-fragment.adp]
        #ns_log notice "DIRECT tagset parse result <$direct>"

        set result [ns_adp_parse -string {
            <% ns_adp_include -tagset adp-test-include adp-tagset-fragment.adp %>
        }]
        rename ::__adp_tag_include_default ""
        rename ::__adp_tag_include_named ""

        ns_return 200 text/plain [string trim $result]
    }
} -body {
    nstest::http -getbody 1 GET /adp-tagset-include
} -cleanup {
    ns_unregister_op GET /adp-tagset-include
    file delete -force $::ns_adp_test_fragment
    unset -nocomplain ::ns_adp_test_fragment
} -result {200 NAMED}

